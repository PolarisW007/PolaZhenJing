# PolaZhenjing Backend Environment Variables
# Copy this to .env and fill in your values.

# Database
DATABASE_URL=postgresql+asyncpg://polazj:polazj_secret@localhost:5432/polazj_db

# JWT
JWT_SECRET_KEY=change-me-to-a-strong-random-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Provider: "openai" or "ollama"
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Ollama (if using local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Site
SITE_BASE_URL=https://yourusername.github.io/PolaZhenJing
SITE_DIR=/site

# CORS (comma-separated in env, but settings expects a JSON list)
# Set via docker-compose or directly
DEBUG=false
